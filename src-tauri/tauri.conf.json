{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AceStar Nexus",
  "version": "0.1.0",
  "identifier": "com.acestar.nexus",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
      "windows": [
        {
          "label": "widget",
          "title": "AceStar Nexus",
          "visibleOnAllWorkspaces": true,
          "width": 520,
          "height": 160,
          "resizable": true,
          "fullscreen": false,
          "alwaysOnTop": false,
          "decorations": false,
          "transparent": true,
          "x": 20,
          "y": 20
        }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
        "bin/acestar-backend",
        "bin/github-provider",
        "bin/leetcode-provider",
        "bin/fitness-provider"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
